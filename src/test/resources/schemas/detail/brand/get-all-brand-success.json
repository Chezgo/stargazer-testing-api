{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Brand Response Schema",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "name"],
    "properties": {
      "id": {
        "type": "integer",
        "minimum": 1
      },
      "name": {
        "type": "string",
        "minLength": 1,
        "maxLength": 50
      },
      "description": {
        "type": ["string", "null"],
        "maxLength": 255
      }
    },
    "additionalProperties": false
  }
}