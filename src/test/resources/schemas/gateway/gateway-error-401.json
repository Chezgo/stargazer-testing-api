{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Gateway Authorization Error Response Schema (401)",
  "type": "object",
  "required": ["error", "errorMessage"],
  "properties": {
    "error": {
      "type": "string",
      "const": "Authorization error"
    },
    "errorMessage": {
      "type": "object",
      "required": ["message"],
      "properties": {
        "message": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}