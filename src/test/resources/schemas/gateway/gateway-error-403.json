{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Gateway Forbidden Error Response Schema (403)",
  "type": "object",
  "required": ["message", "http_status_code"],
  "properties": {
    "message": {
      "type": "string",
      "minLength": 1
    },
    "http_status_code": {
      "type": "integer",
      "const": 403
    }
  },
  "additionalProperties": false
}